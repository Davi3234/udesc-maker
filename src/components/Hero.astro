---
import garotoComRobo from "../images/imagem-garoto.svg";

interface Props {
  selo?: string
  titulo?: string
  descricao?: string
  textoBotao?: string
  linkBotao?: string
  imagem?: {
    src?: string
    alt?: string
  }
}

const {
  selo = "Educação Maker",
  titulo = "Explore projetos maker e descubra como aprender ciência criando com as próprias mãos.",
  descricao = "Uma plataforma da UDESC para divulgar ciência e tecnologia para a comunidade através da prática e da criatividade.",
  textoBotao = "Explorar Projetos",
  linkBotao = "/projetos",
  imagem: {
    src: imagemSrc = garotoComRobo.src,
    alt: imagemAlt = "Ilustração de estudante com robô",
  } = {}
} = Astro.props;
---

<section class="hero">
  <div class="container hero__inner">
    <div class="hero__content">
      <span class="hero__badge">
        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M12 2L2 7l10 5 10-5-10-5z"/><path d="M2 17l10 5 10-5"/><path d="M2 12l10 5 10-5"/>
        </svg>

        {selo}
      </span>

      <h1 class="hero__title">{titulo}</h1>
      <p class="hero__description">{descricao}</p>

      <a href={linkBotao} class="hero__cta">
        {textoBotao}
      </a>
    </div>

    <div class="hero__image-wrapper">
      <div class="hero__image-card">
        <img src={imagemSrc} alt={imagemAlt} class="hero__image" width="480" height="400" loading="eager" />

        <div class="hero__image-badge" aria-hidden="true">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
            <path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"/>
          </svg>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .hero {
    background: var(--gray-50);
    padding-block: 80px 72px;
  }

  .hero__inner {
    display: grid;
    grid-template-columns: 1fr 1fr;
    align-items: center;
    gap: 64px;
  }

  .hero__content {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 20px;
  }

  .hero__badge {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 6px 14px;
    border-radius: 999px;
    border: 1px solid var(--green-600);
    color: var(--green-700);
    font-size: .8rem;
    font-weight: 600;
    font-family: var(--font-display);
    letter-spacing: .02em;
  }

  .hero__title {
    font-family: var(--font-display);
    font-size: clamp(2rem, 4vw, 2.75rem);
    font-weight: 800;
    line-height: 1.15;
    color: var(--gray-900);
    letter-spacing: -.02em;
  }

  .hero__description {
    font-size: 1rem;
    line-height: 1.65;
    color: var(--gray-500);
    max-width: 42ch;
  }

  .hero__cta {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 14px 28px;
    border-radius: var(--radius-md);
    background: var(--green-800);
    color: var(--white);
    font-family: var(--font-display);
    font-size: .95rem;
    font-weight: 600;
    transition: background var(--transition), transform var(--transition), box-shadow var(--transition);
  }

  .hero__cta:hover {
    background: var(--green-900);
    transform: translateY(-2px);
    box-shadow: var(--shadow-md);
  }

  .hero__cta:active {
    transform: translateY(0); }

  .hero__image-wrapper {
    display: flex; justify-content: center; }

  .hero__image-card {
    position: relative;
    border-radius: var(--radius-xl);
    background: var(--white);
    box-shadow: var(--shadow-lg);
    overflow: visible;
    padding: 24px;
  }

  .hero__image {
    border-radius: var(--radius-lg);
    object-fit: cover;
    width: 100%;
    max-width: 420px;
  }

  .hero__image-badge {
    position: absolute;
    bottom: -16px;
    right: -16px;
    width: 52px;
    height: 52px;
    border-radius: var(--radius-md);
    background: var(--red-500);
    color: var(--white);
    display: grid;
    place-items: center;
    box-shadow: var(--shadow-md);
  }

  @media (max-width: 768px) {
    .hero__inner {
      grid-template-columns: 1fr;
      gap: 40px;
    }
    .hero__image-wrapper {
       order: -1; }
  }
</style>

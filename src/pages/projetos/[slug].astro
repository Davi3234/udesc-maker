---
import Footer from "../../components/Footer.astro";
import Navbar from "../../components/Navbar.astro";
import MainLayout from "../../layouts/MainLayout.astro";
import ageIcon from "./assets/ageIcon.png";
import autorIcon from "./assets/autorIcon.png";
import durationIcon from "./assets/durationIcon.png";
import levelIcon from "./assets/levelIcon.png";

export async function getStaticPaths() {
  const modulos = import.meta.glob<{
    frontmatter: Record<string, unknown>;
    compiledContent: () => string;
  }>("../../content/projects/*.md", { eager: true });

  return Object.entries(modulos).map(([caminho, modulo]) => ({
    params: { slug: caminho.split("/").pop()!.replace(/\.md$/, "") },
    props: { modulo },
  }));
}

interface Frontmatter {
  titulo?: string;
  resumo?: string;
  categoria?: string;
  nivel?: string;
  idadeMinima?: number;
  duracao?: number;
  autor?: string;
  tags?: string[];
  imagem?: string;
}

const { modulo } = Astro.props as {
  modulo: { frontmatter: Frontmatter; compiledContent: () => string };
};

const fm = modulo.frontmatter;
const conteudo = modulo.compiledContent();

const NIVEL: Record<string, { label: string; cor: string }> = {
  iniciante: { label: "Iniciante", cor: "var(--green-600)" },
  intermediário: { label: "Intermediário", cor: "#d97706" },
  avançado: { label: "Avançado", cor: "var(--red-500)" },
};
const nivel = NIVEL[fm.nivel ?? ""] ?? NIVEL.iniciante;

// const ICONE_CAT: Record<string, string> = {
//   "Robótica": "🤖", "Eletrônica": "⚡", "Fabricação 3D": "🖨️",
//   "IoT & Sensores": "📡", "Aeroespacial": "🚀", "Programação": "💻",
// };

function fmtDuracao(h: number) {
  if (h < 1) return `${Math.round(h * 60)} min`;
  return h === 1 ? "1 hora" : `${h} horas`;
}
---

<MainLayout
  titulo={`${fm.titulo ?? "Projeto"} — UDESC Maker`}
  descricao={fm.resumo}
>
  <Navbar />

  <main class="project-detail-main">
    <section class="project-detail-section">
      <nav class="project-detail-nav">
        <a class="project-detail-anchor" href="/udesc-maker">Início</a> /
        <a class="project-detail-anchor" href="/udesc-maker/projetos"
          >Projetos</a
        > /
        <p class="project-detail-current-project">{fm.titulo}</p>
      </nav>

      <h1 class="project-detail-title">{fm.titulo}</h1>
      <div class="project-detail-badges">
        <span class="project-detail-categoria">{fm.categoria}</span>
        {
          (fm.tags?.length ?? 0) > 0 && (
            <ul class="project-detail-tag-list" aria-label="Tags do projeto">
              {fm.tags!.map((t) => (
                <li class="project-detail-tag">{t}</li>
              ))}
            </ul>
          )
        }
      </div>
      <p class="project-detail-resumo">{fm.resumo}</p>
    </section>
    <section class="project-detail-section">
      <div class="projeto-detail-img-wrapper">
        <img
          class="project-detail-img"
          src={fm.imagem}
          alt={fm.titulo ?? "Imagem do projeto"}
          width="1000"
          height="480"
        />
      </div>
      <div class="project-detail-info-container">
        <div class="project-detail-info-card">
          <img src={autorIcon.src} alt="Imagem do autor" />
          <h4 class="project-detail-info-card-title">Autor</h4>
          <p class="project-detail-info-card-content"><b>{fm.autor}</b></p>
        </div>
        <div class="project-detail-info-card">
          <img src={ageIcon.src} alt="Imagem da idade mínima" />
          <h4 class="project-detail-info-card-title">Idade Mínima</h4>
          <p class="project-detail-info-card-content">
            <b>{fm.idadeMinima}+ anos</b>
          </p>
        </div>
        <div class="project-detail-info-card">
          <img src={durationIcon.src} alt="Imagem da duração" />
          <h4 class="project-detail-info-card-title">Duração</h4>
          <p class="project-detail-info-card-content">
            <b>{fmtDuracao(fm.duracao ?? 0)}</b>
          </p>
        </div>
        <div class="project-detail-info-card">
          <img src={levelIcon.src} alt="Imagem do nível de dificuldade" />
          <h4 class="project-detail-info-card-title">Nível</h4>
          <p class="project-detail-info-card-content"><b>{nivel.label}</b></p>
        </div>
      </div>
    </section>
    <section class="project-detail-section">
      <article class="prose" set:html={conteudo} />
    </section>
  </main>

  <Footer />
</MainLayout>

<style>
  .project-detail-main {
    width: 100%;
    margin: 0 auto;
    background: var(--gray-50);
    border-bottom: 1px solid var(--gray-100);
    padding: 40px 8% 0 8%;
  }

  .project-detail-nav {
    display: flex;
    flex-direction: row;
    flex-wrap: nowrap;
    gap: 6px;
  }

  .project-detail-anchor {
    font-size: 14px;
    color: var(--gray-500);
    transition: color var(--transition);
    font-weight: 500;
  }

  .project-detail-current-project {
    font-size: 14px;
    color: var(--green-700);
    font-weight: 600;
  }

  .project-detail-title {
    margin-top: 40px;
    font-family: var(--font-display);
    font-size: clamp(1.8rem, 4vw, 2.6rem);
    font-weight: 800;
    color: var(--black-900);
    letter-spacing: -0.02em;
    line-height: 1.2;
    margin-bottom: 12px;
  }

  .project-detail-badges {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
    margin-bottom: 24px;
  }

  .project-detail-tag-list {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    list-style: none;
  }

  .project-detail-tag,
  .project-detail-categoria {
    padding: 4px 12px;
    border-radius: 999px;
    background: var(--green-100);
    color: var(--green-700);
    font-family: var(--font-display);
    font-size: 0.75rem;
    font-weight: 600;
  }

  .project-detail-resumo {
    font-size: 1.05rem;
    color: var(--gray-500);
    line-height: 1.65;
    max-width: 62ch;
    margin-bottom: 24px;
  }

  .project-detail-img {
    width: 100%;
    max-width: 1140px;
    max-height: 480px;
    margin: 0 auto 0 0;
    object-fit: cover;
    border-radius: var(--radius-xl);
    box-shadow: var(--shadow-md);
    text-align: center;
  }

  .projeto-detail-img-wrapper {
    padding-block: 32px;
  }

  .project-detail-info-container {
    display: flex;
    flex-direction: row;
    flex-wrap: wrap;
    gap: 20px;
    margin-bottom: 32px;
    justify-content: space-between;
    max-width: 1140px;
    margin: 0 auto 0 0;
  }

  .project-detail-info-card {
    background: var(--white);
    border: 1px solid var(--gray-200);
    border-radius: var(--radius-lg);
    padding: 20px;
    flex: 1 1 220px;
    max-width: 280px;
    box-shadow: var(--shadow-sm);
  }

  .project-detail-info-card-title {
    font-family: var(--font-display);
    font-size: 0.9rem;
    font-weight: 600;
    color: var(--gray-500);
    margin-top: 12px;
    margin-bottom: 8px;
  }

  .project-detail-info-card-content {
    font-size: 16px;
    color: var(--gray-700);
  }

  .prose {
    margin-top: 80px;
    width: 1140px;
    max-width: 80%;
    color: var(--gray-700);
    line-height: 1.8;
    font-size: 1rem;
    counter-reset: step-counter;
  }
  .prose :global(h2) {
    font-family: var(--font-display);
    font-weight: 600;
    color: var(--gray-900);
    padding-bottom: 0.4em;
    border-left: 8px solid var(--green-700);
    border-radius: 8px;
    padding-left: 8px;
    margin: 40px 0 8px 0;
  }
  .prose :global(h3) {
    counter-increment: step-counter;
    display: flex;
    align-items: center;
    gap: 16px;
    font-size: 1.25rem;
    font-weight: 700;
    color: #111827;
    margin-top: 40px;
  }

  .prose :global(h3)::before {
    content: counter(step-counter);
    background-color: #064e3b;
    color: white;
    width: 32px;
    height: 32px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 0.9rem;
    flex-shrink: 0;
  }
  .prose :global(p) {
    padding-left: 48px;
    margin-bottom: 1.1em;
    color: var(--gray-500);
  }

  .prose :global(img) {
    width: 80%;
    margin: 0 auto;
    border-radius: 4px;
    border: 1px solid var(--green-700);
  }

  .prose :global(ul),
  .prose :global(ol) {
    display: flex;
    flex-direction: row;
    flex-wrap: wrap;
    align-items: flex-start;
    align-content: start;
    justify-content: flex-start;
    gap: 12px;
  }
  .prose :global(li) {
    width: 360px;
    height: max-content;
    min-height: 60px;
    padding: 2% 0 0 8px;
    color: #334155;
    font-size: 16px;
    font-weight: 500;
    border-bottom: 1px solid var(--gray-200);
    border-radius: 8px;
    background-color: transparent;
    list-style-type: none;
    border-bottom: 2px solid var(--gray-100);
  }
  .prose :global(strong) {
    font-weight: 700;
    color: var(--gray-900);
  }
  .prose :global(code) {
    background: var(--gray-100);
    padding: 0.15em 0.4em;
    border-radius: 4px;
    font-size: 0.875em;
    font-family: monospace;
  }
  .prose :global(pre) {
    background: var(--gray-900);
    color: var(--gray-100);
    padding: 1.2em 1.5em;
    border-radius: var(--radius-md);
    overflow-x: auto;
    margin-block: 1.2em;
  }
  .prose :global(pre code) {
    background: none;
    padding: 0;
  }
</style>

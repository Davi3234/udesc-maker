---
import Footer from "../../components/Footer.astro";
import Navbar from "../../components/Navbar.astro";
import MainLayout from "../../layouts/MainLayout.astro";

export async function getStaticPaths() {
  const modulos = import.meta.glob<{
    frontmatter: Record<string, unknown>;
    compiledContent: () => string;
  }>("../../content/projects/*.md", { eager: true });

  return Object.entries(modulos).map(([caminho, modulo]) => ({
    params: { slug: caminho.split("/").pop()!.replace(/\.md$/, "") },
    props: { modulo },
  }));
}

interface Frontmatter {
  titulo?: string;
  resumo?: string;
  categoria?: string;
  nivel?: string;
  idadeMinima?: number;
  duracao?: number;
  autor?: string;
  tags?: string[];
  imagem?: string;
}

const { modulo } = Astro.props as {
  modulo: { frontmatter: Frontmatter; compiledContent: () => string };
};

const fm = modulo.frontmatter;
const conteudo = modulo.compiledContent();

const NIVEL: Record<string, { label: string; cor: string }> = {
  iniciante:    { label: "Iniciante",     cor: "var(--green-600)" },
  intermediário: { label: "Intermediário", cor: "#d97706"          },
  avançado:     { label: "Avançado",      cor: "var(--red-500)"   },
};
const nivel = NIVEL[fm.nivel ?? ""] ?? NIVEL.iniciante;

// const ICONE_CAT: Record<string, string> = {
//   "Robótica": "🤖", "Eletrônica": "⚡", "Fabricação 3D": "🖨️",
//   "IoT & Sensores": "📡", "Aeroespacial": "🚀", "Programação": "💻",
// };

function fmtDuracao(h: number) {
  if (h < 1) return `${Math.round(h * 60)} min`;
  return h === 1 ? "1 hora" : `${h} horas`;
}
---

<MainLayout
  titulo={`${fm.titulo ?? "Projeto"} — UDESC Maker`}
  descricao={fm.resumo}
>
  <Navbar />

  <main class="project-detail-main">
    <section class="project-detail-section">
      <nav class="project-detail-nav">
          <a class="project-detail-anchor" href="/udesc-maker">Início</a> / 
          <a class="project-detail-anchor" href="/udesc-maker/projetos">Projetos</a> /
          <p class="project-detail-current-project">{fm.titulo}</p>
        </nav>

        <h1 class="project-detail-title">{fm.titulo}</h1>
        <div class="project-detail-badges">
          <span class="project-detail-categoria">{fm.categoria}</span>
          {(fm.tags?.length ?? 0) > 0 && (
          <ul class="project-detail-tag-list" aria-label="Tags do projeto">
            {fm.tags!.map((t) => <li class="project-detail-tag">{t}</li>)}
          </ul>
        )}
        </div>
        <p class="project-detail-resumo">{fm.resumo}</p>
    </section>
    <section class="project-detail-section">
        <div class="projeto-detail-img-wrapper">
          <img class="project-detail-img" src={fm.imagem} alt={fm.titulo ?? "Imagem do projeto"} 
            width="1140" height="480"/>
        </div>  
        <div class="project-detail-info-container">
          <div class="project-detail-info-card">
            <img src="../projetos/assets/" alt="Imagem do autor" />
            <h4 class="project-detail-info-card-title">Autor</h4>
            <p class="project-detail-info-card-content">{fm.autor}</p>
          </div>
          <div class="project-detail-info-card">
            <img src="../projetos/assets/" alt="Imagem da idade mínima" />
            <h4 class="project-detail-info-card-title">Idade Mínima</h4>
            <p class="project-detail-info-card-content">{fm.idadeMinima}+ anos</p>
          </div>
          <div class="project-detail-info-card">
            <img src="../projetos/assets/durationIcon.png" alt="Imagem da duração" />
            <h4 class="project-detail-info-card-title">Duração</h4>
            <p class="project-detail-info-card-content">{fmtDuracao(fm.duracao ?? 0)}</p>
          </div>
          <div class="project-detail-info-card">
            <img src="../projetos/assets/levelIcon.png" alt="Imagem do nível de dificuldade" />
            <h4 class="project-detail-info-card-title">Nível</h4>
            <p class="project-detail-info-card-content">{nivel.label}</p>
          </div>
        </div>
    </section>
    <section class="project-detail-section">
      <article class="prose" set:html={conteudo} />
    </section>
  </main>

  <Footer />
</MainLayout>

<style>

  .project-detail-main {
    width: 100%;
    margin: 0 auto;
    background: var(--gray-50);
    border-bottom: 1px solid var(--gray-100);
    padding: 40px 8% 0 8%;
  }

  .project-detail-nav {
    display: flex;
    flex-direction: row;
    flex-wrap: nowrap;
    gap: 6px;
  }

  .project-detail-anchor {
    font-size: 14px;
    color: var(--gray-500);
    transition: color var(--transition);
    font-weight: 500;
  }

  .project-detail-current-project {
    font-size: 14px;
    color: var(--green-700);
    font-weight: 600;
  }

  .project-detail-title {
    font-family: var(--font-display);
    font-size: clamp(1.8rem, 4vw, 2.6rem);
    font-weight: 800;
    color: var(--black-900);
    letter-spacing: -.02em;
    line-height: 1.2;
    margin-bottom: 12px;
  }

  .project-detail-badges {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
    margin-bottom: 24px;
  }

  .project-detail-tag-list { 
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    list-style: none;
  }

  .project-detail-tag, .project-detail-categoria {
    padding: 4px 12px;
    border-radius: 999px;
    background: var(--green-100);
    color: var(--green-700);
    font-family: var(--font-display);
    font-size: .75rem;
    font-weight: 600;
  }

  .project-detail-resumo {
    font-size: 1.05rem;
    color: var(--gray-500);
    line-height: 1.65;
    max-width: 62ch;
    margin-bottom: 24px;
  }
  
  .project-detail-img {
    width: 100%;
    max-height: 480px;
    object-fit: cover;
    border-radius: var(--radius-xl);
    box-shadow: var(--shadow-md);
  }

  .projeto-detail-img-wrapper { 
    padding-block: 32px; 
  }

  .project-detail-info-container {
    display: flex;
    flex-direction: row;
    flex-wrap: wrap;
    gap: 20px;
    margin-bottom: 32px;
    justify-content: space-between;
  }

  .project-detail-info-card {
    background: var(--white);
    border: 1px solid var(--gray-200);
    border-radius: var(--radius-lg);
    padding: 20px;
    flex: 1 1 220px;
    max-width: 280px;
    box-shadow: var(--shadow-sm);
  }


  .prose {
    max-width: 72ch;
    color: var(--gray-700);
    line-height: 1.8;
    font-size: 1rem;
  }
  .prose :global(h2) {
    font-family: var(--font-display);
    font-weight: 600;
    color: var(--gray-900);
    padding-bottom: .4em;
    border-left: 8px solid var(--green-500);
    border-radius: 8px;
    padding-left: 8px;
    margin: 16px 0 8px 0;
  }
  .prose :global(h3) {
    font-family: var(--font-display);
    font-size: 1.1rem;
    font-weight: 700;
    color: var(--gray-900);
    margin-block: 1.6em .5em;
  }
  .prose :global(p)  { 
    margin-bottom: 1.1em;
    color: var(--gray-500);
   }
  .prose :global(ul),
  .prose :global(ol) {
    display: flex;
    flex-direction: row;
    flex-wrap: wrap;
    align-items: center;
    justify-content: space-evenly;
    gap: 12px;
  }
  .prose :global(li) {
    width: 360px;
    height: 60px;
    padding-left: 8px;
    color: var(--gray-900);
    border-bottom: 1px solid var(--gray-200);
    border-radius: 8px;
    background-color: white;
    list-style-type: none;
  }
  /* .prose :global(strong) { font-weight: 700; color: var(--gray-900); } */
  /* .prose :global(code) {
    background: var(--gray-100);
    padding: .15em .4em;
    border-radius: 4px;
    font-size: .875em;
    font-family: monospace;
  } */
  .prose :global(pre) {
    background: var(--gray-900);
    color: var(--gray-100);
    padding: 1.2em 1.5em;
    border-radius: var(--radius-md);
    overflow-x: auto;
    margin-block: 1.2em;
  }
  .prose :global(pre code) { background: none; padding: 0; }
</style>